# Copy to .env and fill in. Never commit real secrets.

# --- apps/api + apps/worker ---
# MongoDB connection string (local docker-compose default shown)
MONGODB_URI=mongodb://localhost:27017/veda-ai
# Redis connection string (local docker-compose default shown)
REDIS_URL=redis://localhost:6379

# --- apps/worker: AWS Bedrock (Claude via the Converse API, structured outputs) ---
# AWS region hosting the model / cross-region inference profile
AWS_REGION=us-east-1
# Bedrock model id / inference profile (us.* cross-region profile recommended)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Max output tokens per generation call
BEDROCK_MAX_TOKENS=8192
# Bedrock API key (bearer token) — consumed by the AWS SDK. Never commit a real value.
AWS_BEARER_TOKEN_BEDROCK=

# --- apps/api ---
# Port the Express server listens on
PORT=4000
# Allowed CORS origin for the browser client
CLIENT_ORIGIN=http://localhost:3000

# --- apps/web (exposed to the browser, must be NEXT_PUBLIC_*) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
# Optional: run the web app against an in-memory mock of the REST + realtime
# contract (no backend required) to preview the full flow. Defaults to false.
NEXT_PUBLIC_USE_MOCK=false
